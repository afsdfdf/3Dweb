# Vercel production environment template
# Copy values into Vercel Project Settings -> Environment Variables.
# Keep secrets out of git. Replace every placeholder before production deploy.

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
NODE_ENV=production
ACTIVE_APP_DATA_MODE=supabase-postgres
TARGET_APP_DATA_MODE=supabase-postgres

NEXT_PUBLIC_APP_URL=https://your-production-domain.example.com
CANONICAL_APP_URL=https://your-production-domain.example.com
ALLOWED_REQUEST_ORIGINS=https://your-production-domain.example.com

PAYLOAD_SECRET=replace_with_a_long_random_secret_at_least_32_characters

# -----------------------------------------------------------------------------
# Database
# Use one canonical runtime connection source.
# -----------------------------------------------------------------------------
DATABASE_PROVIDER=postgres
DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_SSL_REJECT_UNAUTHORIZED=false
POSTGRES_POOL_MAX=5
POSTGRES_POOL_MIN=0
POSTGRES_POOL_CONNECTION_TIMEOUT_MS=60000
POSTGRES_POOL_IDLE_TIMEOUT_MS=10000

# -----------------------------------------------------------------------------
# Supabase application access
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_supabase_anon_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace_with_supabase_publishable_key_if_used

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_PUBLISHABLE_KEY=replace_with_supabase_publishable_key_if_used
SUPABASE_SECRET_KEY=replace_with_supabase_secret_key_if_used
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
SUPABASE_JWT_SECRET=replace_with_supabase_jwt_secret

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace_with_stripe_publishable_key
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret

# -----------------------------------------------------------------------------
# Email
# Required for verification email and password reset email in production.
# -----------------------------------------------------------------------------
EMAIL_FROM_ADDRESS=no-reply@your-production-domain.example.com
EMAIL_FROM_NAME=Thorns Tavern
SMTP_HOST=smtp.your-provider.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_with_smtp_user
SMTP_PASS=replace_with_smtp_password
SMTP_SKIP_VERIFY=false

# -----------------------------------------------------------------------------
# Object storage
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=replace_with_aws_access_key_id
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret_access_key
S3_BUCKET=replace_with_s3_bucket_name
S3_REGION=us-east-1
S3_PREFIX=media
S3_CDN_URL=
S3_SIGNED_DOWNLOADS=true

# Remote asset allowlist should contain the exact trusted hostnames only.
AI_REMOTE_ASSET_ALLOWLIST=replace_with_allowed_asset_hostnames

# -----------------------------------------------------------------------------
# AI provider runtime
# -----------------------------------------------------------------------------
AI_PROVIDER=meshy
MESHY_API_KEY=replace_with_meshy_api_key
MESHY_API_BASE_URL=https://api.meshy.ai/openapi/v1
PROVIDER_REQUEST_TIMEOUT_MS=30000
TASK_TIMEOUT_MS=900000
TASK_SYNC_INTERVAL_MS=5000
NEXT_PUBLIC_TASK_SYNC_INTERVAL_MS=5000
MAX_UPLOAD_BYTES=8388608
NEXT_PUBLIC_MAX_UPLOAD_BYTES=8388608

# -----------------------------------------------------------------------------
# Optional Gemini image generation runtime
# -----------------------------------------------------------------------------
GEMINI_IMAGE_API_KEY=
GEMINI_IMAGE_API_BASE_URL=
GEMINI_IMAGE_MODEL=
GEMINI_IMAGE_THIRD_PARTY_API_KEY=
GEMINI_IMAGE_THIRD_PARTY_BASE_URL=
GEMINI_IMAGE_THIRD_PARTY_MODEL=

# -----------------------------------------------------------------------------
# Optional shared KV / rate limit backend
# -----------------------------------------------------------------------------
REDIS_URL=

# -----------------------------------------------------------------------------
# Security toggles
# -----------------------------------------------------------------------------
TRUST_PROXY_HEADERS=true
ENABLE_GRAPHQL_INTROSPECTION=false
ENABLE_GRAPHQL_PLAYGROUND=false
ENABLE_PUBLIC_ACCESS_ENDPOINT=false

# -----------------------------------------------------------------------------
# Optional rate-limit overrides
# Leave unset unless load testing justifies custom values.
# -----------------------------------------------------------------------------
AI_SUBMIT_RATE_LIMIT_MAX=
AI_SUBMIT_RATE_LIMIT_WINDOW_MS=
AI_SYNC_RATE_LIMIT_MAX=
AI_SYNC_RATE_LIMIT_WINDOW_MS=
AI_IMAGE_SUBMIT_RATE_LIMIT_MAX=
AI_IMAGE_SUBMIT_RATE_LIMIT_WINDOW_MS=
MODEL_PREVIEW_RATE_LIMIT_MAX=
MODEL_PREVIEW_RATE_LIMIT_WINDOW_MS=
ORDER_CREATE_RATE_LIMIT_MAX=
ORDER_CREATE_RATE_LIMIT_WINDOW_MS=
ORDER_SYNC_RATE_LIMIT_MAX=
ORDER_SYNC_RATE_LIMIT_WINDOW_MS=
SUBSCRIPTION_CHECKOUT_RATE_LIMIT_MAX=
SUBSCRIPTION_CHECKOUT_RATE_LIMIT_WINDOW_MS=
SUBSCRIPTION_PORTAL_RATE_LIMIT_MAX=
SUBSCRIPTION_PORTAL_RATE_LIMIT_WINDOW_MS=
SUBSCRIPTION_SYNC_RATE_LIMIT_MAX=
SUBSCRIPTION_SYNC_RATE_LIMIT_WINDOW_MS=
SOCIAL_REACTION_WRITE_RATE_LIMIT_MAX=
SOCIAL_REACTION_WRITE_RATE_LIMIT_WINDOW_MS=
SOCIAL_COMMENT_WRITE_RATE_LIMIT_MAX=
SOCIAL_COMMENT_WRITE_RATE_LIMIT_WINDOW_MS=
SOCIAL_FOLLOW_WRITE_RATE_LIMIT_MAX=
SOCIAL_FOLLOW_WRITE_RATE_LIMIT_WINDOW_MS=
