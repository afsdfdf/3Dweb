# Vercel preview / test environment template
# Safe for preview deployments. Replace placeholders with real preview/test values.

NODE_ENV=production
ACTIVE_APP_DATA_MODE=supabase-postgres
TARGET_APP_DATA_MODE=supabase-postgres

NEXT_PUBLIC_APP_URL=https://your-preview-domain.example.com
CANONICAL_APP_URL=https://your-preview-domain.example.com
ALLOWED_REQUEST_ORIGINS=https://your-preview-domain.example.com

PAYLOAD_SECRET=replace_with_a_long_random_secret_at_least_32_characters

DATABASE_PROVIDER=postgres
DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_SSL_REJECT_UNAUTHORIZED=false
POSTGRES_POOL_MAX=5
POSTGRES_POOL_MIN=0
POSTGRES_POOL_CONNECTION_TIMEOUT_MS=60000
POSTGRES_POOL_IDLE_TIMEOUT_MS=10000

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_supabase_anon_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace_with_supabase_publishable_key_if_used

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_PUBLISHABLE_KEY=replace_with_supabase_publishable_key_if_used
SUPABASE_SECRET_KEY=replace_with_supabase_secret_key_if_used
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
SUPABASE_JWT_SECRET=replace_with_supabase_jwt_secret

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace_with_stripe_test_publishable_key
STRIPE_SECRET_KEY=replace_with_stripe_test_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_test_webhook_secret

EMAIL_FROM_ADDRESS=no-reply@preview.example.com
EMAIL_FROM_NAME=Thorns Tavern Preview
SMTP_HOST=smtp.your-provider.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_with_preview_smtp_user
SMTP_PASS=replace_with_preview_smtp_password
SMTP_SKIP_VERIFY=false

AWS_ACCESS_KEY_ID=replace_with_aws_access_key_id
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret_access_key
S3_BUCKET=replace_with_preview_bucket_name
S3_REGION=us-east-1
S3_PREFIX=media
S3_CDN_URL=
S3_SIGNED_DOWNLOADS=true

AI_REMOTE_ASSET_ALLOWLIST=replace_with_allowed_asset_hostnames

AI_PROVIDER=meshy
MESHY_API_KEY=replace_with_meshy_api_key
MESHY_API_BASE_URL=https://api.meshy.ai/openapi/v1
PROVIDER_REQUEST_TIMEOUT_MS=30000
TASK_TIMEOUT_MS=900000
TASK_SYNC_INTERVAL_MS=5000
NEXT_PUBLIC_TASK_SYNC_INTERVAL_MS=5000
MAX_UPLOAD_BYTES=8388608
NEXT_PUBLIC_MAX_UPLOAD_BYTES=8388608

GEMINI_IMAGE_API_KEY=
GEMINI_IMAGE_API_BASE_URL=
GEMINI_IMAGE_MODEL=
GEMINI_IMAGE_THIRD_PARTY_API_KEY=
GEMINI_IMAGE_THIRD_PARTY_BASE_URL=
GEMINI_IMAGE_THIRD_PARTY_MODEL=

REDIS_URL=

TRUST_PROXY_HEADERS=true
ENABLE_GRAPHQL_INTROSPECTION=false
ENABLE_GRAPHQL_PLAYGROUND=false
ENABLE_PUBLIC_ACCESS_ENDPOINT=false
