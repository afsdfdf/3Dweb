PAYLOAD_SECRET=replace_with_a_long_random_secret
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Database selection
# Option 1: direct connection string
# DATABASE_PROVIDER=postgres
# DATABASE_URL=postgresql://db_user:db_password@your-rds-endpoint:5432/payload_app?sslmode=require

# Option 2: let the backend compose the AWS RDS PostgreSQL connection string
# DATABASE_PROVIDER=postgres
# AWS_RDS_HOST=your-rds-endpoint.region.rds.amazonaws.com
# AWS_RDS_PORT=5432
# AWS_RDS_DB_NAME=payload_app
# AWS_RDS_USERNAME=payload_user
# AWS_RDS_PASSWORD=replace_with_database_password
# AWS_RDS_SSL_MODE=require
# AWS_RDS_SSL_REJECT_UNAUTHORIZED=false
# AWS_RDS_SCHEMA=public

# Local fallback
DATABASE_URL=file:./payload.db

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email
EMAIL_FROM_NAME=MiniForge AI 3D
EMAIL_FROM_ADDRESS=no-reply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SKIP_VERIFY=false

# Optional AWS S3 storage
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# S3_BUCKET=your-media-bucket
# S3_REGION=ap-southeast-1
# S3_PREFIX=media
# S3_CDN_URL=https://cdn.example.com
# S3_SIGNED_DOWNLOADS=true
