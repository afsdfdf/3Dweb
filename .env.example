PAYLOAD_SECRET=replace_with_a_long_random_secret
CRON_SECRET=replace_with_a_long_random_secret_for_vercel_cron
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
# Production note: set CANONICAL_APP_URL to the public origin, for example https://app.example.com
# CANONICAL_APP_URL=https://app.example.com
ALLOWED_DEV_ORIGINS=127.0.0.1,localhost
ALLOWED_REQUEST_ORIGINS=http://127.0.0.1:3000
PAYLOAD_COOKIE_PREFIX=payload

# Database selection
# Use one canonical Postgres connection string. Supabase Postgres is the current production direction.
# Pool defaults below can be overridden after load testing.
# POSTGRES_POOL_MAX=20
# POSTGRES_POOL_MIN=2
# POSTGRES_POOL_IDLE_TIMEOUT_MS=30000
# POSTGRES_POOL_CONNECTION_TIMEOUT_MS=60000

# Required runtime database
DATABASE_PROVIDER=postgres
DATABASE_URL=postgresql://postgres:replace_with_database_password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# GLB preview optimization
MODEL_OPTIMIZATION_ENABLED=false
MODEL_OPTIMIZATION_WORKER_URL=
MODEL_OPTIMIZATION_CALLBACK_SECRET=
MODEL_OPTIMIZATION_MODE=conservative
MODEL_OPTIMIZATION_MAX_ACTIVE=24
MODEL_OPTIMIZATION_DISPATCH_BATCH_SIZE=6
MODEL_OPTIMIZATION_JOB_TIMEOUT_SECONDS=420
MODEL_OPTIMIZATION_SOURCE_URL_TTL_SECONDS=900

# Supabase project and storage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
# NEXT_PUBLIC_SUPABASE_URL is only needed by browser Supabase helpers.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email
EMAIL_FROM_NAME=Thorns Tavern
EMAIL_FROM_ADDRESS=no-reply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SKIP_VERIFY=false
# Production note: SMTP_SKIP_VERIFY=true is blocked in production startup checks.

# Registration abuse control
# Requests beyond this limit will receive HTTP 429 from middleware.
REGISTER_RATE_LIMIT_MAX=5
REGISTER_RATE_LIMIT_WINDOW_MS=3600000

# Login abuse control
# Repeated failed login attempts from the same IP will be temporarily blocked.
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# GraphQL abuse control
# Production GraphQL requests exceeding these limits will be rejected.
GRAPHQL_MAX_DEPTH=8
GRAPHQL_MAX_COMPLEXITY=250

# Security-sensitive debugging toggles
# Leave these disabled in normal environments to avoid leaking schema or permission maps.
# ENABLE_GRAPHQL_INTROSPECTION=false
# ENABLE_GRAPHQL_PLAYGROUND=false
# ENABLE_PUBLIC_ACCESS_ENDPOINT=false

# AI generation runtime tuning
# Provider concurrency is normally managed in Payload Admin -> AI Provider Settings.
# These environment variables are fallbacks when backend settings are unavailable.
# MESHY_MAX_CONCURRENT_TASKS=20
# IMAGE_GENERATION_MAX_CONCURRENT_TASKS=20
# Local-only demo 3D mock results. Never enable this in production.
# ENABLE_AI_MOCK_RESULTS=false

# Supabase Storage bucket, prefix, public base URL, and signed download settings are managed in
# Admin -> Globals -> Storage Settings. Do not add object-storage provider secrets to NEXT_PUBLIC_* variables.
